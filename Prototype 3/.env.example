# ──────────────────────────────────────────────
# CampOS Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Backend
PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/campos
CORS_ORIGIN=http://localhost:5173

# JWT Configuration (generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# Frontend API URL (Vite build-time variable)
# Split deploy (Vercel UI + Render API): leave unset — defaults to Render in production
# All-in-one Vercel (api/ serverless): set VITE_API_BASE= for same-origin /api
# VITE_API_BASE=https://campos-fmjh.onrender.com

# ──────────────────────────────────────────────
# Vercel Deployment Notes
# ──────────────────────────────────────────────
# Set these in Vercel Project Settings → Environment Variables:
#   MONGODB_URI          — use MongoDB Atlas connection string
#   JWT_ACCESS_SECRET    — generate a random 64-char hex string
#   JWT_REFRESH_SECRET   — generate a different random 64-char hex string
#   CORS_ORIGIN          — your Vercel deployment URL (e.g. https://campos.vercel.app)
#   NODE_ENV             — production

